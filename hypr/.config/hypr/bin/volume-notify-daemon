#!/usr/bin/env bash
set -euo pipefail

SINK="@DEFAULT_AUDIO_SINK@"
TAG="volume"

get_volume_state() {
  local output volume muted

  output="$(wpctl get-volume "$SINK")"

  volume="$(awk '{ printf "%.0f", $2 * 100 }' <<< "$output")"

  if grep -q '\[MUTED\]' <<< "$output"; then
    muted="muted"
  else
    muted="unmuted"
  fi

  printf '%s:%s\n' "$volume" "$muted"
}

notify_volume() {
  local state volume muted

  state="$(get_volume_state)"
  volume="${state%%:*}"
  muted="${state##*:}"

  if (( volume < 0 )); then
    volume=0
  elif (( volume > 100 )); then
    volume=100
  fi

  if [[ "$muted" == "muted" ]]; then
    dunstify \
      -a "volume" \
      -h "string:x-dunst-stack-tag:$TAG" \
      -h "int:value:0" \
      -t 1000 \
      "Volume" "Muted"
  else
    dunstify \
      -a "volume" \
      -h "string:x-dunst-stack-tag:$TAG" \
      -h "int:value:$volume" \
      -t 1000 \
      "Volume" "${volume}%"
  fi
}

last_state="$(get_volume_state)"

pactl subscribe | while read -r line; do
  case "$line" in
    *"Event 'change' on sink"*|*"Event 'change' on server"*)
      current_state="$(get_volume_state)"

      if [[ "$current_state" != "$last_state" ]]; then
        last_state="$current_state"
        notify_volume
      fi
      ;;
  esac
done

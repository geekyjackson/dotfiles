#!/usr/bin/env bash
set -euo pipefail

dir="$HOME/Documents/code/youtube"
py="$dir/.venv/bin/python"
script="$dir/youtube_asmr.py"

[[ -x "$py" ]] || { echo "Missing Python venv: $py" >&2; exit 1; }
[[ -f "$script" ]] || { echo "Missing script: $script" >&2; exit 1; }

case "${1:-}" in
  -h|--help)
    cat <<EOF
Usage: youtube-asmr [OPTIONS]

Run the YouTube ASMR downloader through the VPN wrapper.

Options:
  -h, --help    Show this help message and exit
  -u, --update  Update pip and yt-dlp in the script virtualenv

Examples:
  youtube-asmr
  youtube-asmr --update
EOF
    exit 0
    ;;

  -u|--update)
    "$py" -m pip install -U pip "yt-dlp[default]"
    exit 0
    ;;
esac

exec vpn run "$py" "$script" "$@"
